# Discord-style placeholders for compatibility. This base is WhatsApp-only by default.
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
WELCOME_CHANNEL_ID=
LEAVE_CHANNEL_ID=
KICK_LOG_CHANNEL_ID=

APP_NAME=OnimaiBot
BOT_PREFIX=!
WHATSAPP_PRINT_QR=true
BOT_OWNER_NUMBERS=491234567890
WA_API_BOOTSTRAP_SESSIONS=main-session
WA_API_RETRY_LIMIT=10
ONIMAIBOT_DRY_RUN=false

# Optional event banners. Use URL or local path; path wins only when URL is empty.
WELCOME_BANNER_URL=
LEAVE_BANNER_URL=
KICK_BANNER_URL=
WELCOME_BANNER_PATH=./docs/assets/readme-hero.jpg
LEAVE_BANNER_PATH=./docs/assets/readme-hero.jpg
KICK_BANNER_PATH=./docs/assets/readme-hero.jpg
