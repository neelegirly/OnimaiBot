# Anzeigename der App
APP_NAME=OnimaiBaseV3

# development oder production
NODE_ENV=development

# debug, info, warn, error
LOG_LEVEL=info

# Prefix für Text-Befehle wie !ping
BOT_PREFIX=!

# Hier werden WhatsApp-Sessiondateien gespeichert
WHATSAPP_SESSION_DIR=auth

# QR-Code im Terminal anzeigen
WHATSAPP_PRINT_QR=true

# true = nur lokal testen
# false = echter WhatsApp-Login mit QR-Code
ONIMAIBASEV3_DRY_RUN=true
