{
  "name": "onimaibasev3",
  "version": "1.0.0",
  "description": "Schöne, einfache WhatsApp-Bot-Starter-Base mit main.js, Onicommands und hübscher Konsole.",
  "private": true,
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "start": "node main.js",
    "dev": "node --watch main.js",
    "build": "node scripts/build.js",
    "test": "node --test tests/smoke.test.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --only OnimaiBaseV3",
    "pm2:stop": "pm2 delete OnimaiBaseV3",
    "pm2:restart": "pm2 restart OnimaiBaseV3"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "dotenv": "^17.2.3",
    "pino": "^9.7.0",
    "pm2": "^6.0.8",
    "qrcode-terminal": "^0.12.0"
  }
}
